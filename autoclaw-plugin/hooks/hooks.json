{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/setup.sh\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "chartcode impact-from-diff 2>/dev/null || \"${CLAUDE_PLUGIN_DATA}/bin/chartcode\" impact-from-diff 2>/dev/null || true",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE_PATH=$(cat | jq -r '.tool_input.file_path // empty' 2>/dev/null) && [ -n \"$FILE_PATH\" ] && (chartcode reindex \"$FILE_PATH\" 2>/dev/null || \"${CLAUDE_PLUGIN_DATA}/bin/chartcode\" reindex \"$FILE_PATH\" 2>/dev/null) || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "(chartcode snapshot \"$TRANSCRIPT_PATH\" --all-since-last 2>/dev/null || \"${CLAUDE_PLUGIN_DATA}/bin/chartcode\" snapshot \"$TRANSCRIPT_PATH\" --all-since-last 2>/dev/null) || true"
          }
        ]
      }
    ]
  }
}
